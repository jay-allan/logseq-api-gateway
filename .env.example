# Server
PORT=3000
NODE_ENV=development

# JWT — generate with: openssl rand -base64 48
# Must be at least 32 characters (NIST SP 800-185 recommendation for HMAC-SHA256)
JWT_SECRET=change-me-access-secret-min-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters
JWT_ACCESS_TTL=900        # 15 minutes in seconds
JWT_REFRESH_TTL=604800    # 7 days in seconds

# Logseq HTTP API
LOGSEQ_BASE_URL=http://localhost:12315
LOGSEQ_TOKEN=your-logseq-token

# Database
DB_PATH=./data/gateway.db

# Initial admin (used by seed script only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# Write queue
WRITE_QUEUE_MAX_DEPTH=50
WRITE_QUEUE_TIMEOUT_MS=30000

# Auth endpoint rate limiting (stricter than global)
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW=15 minutes

# CORS — comma-separated list of allowed origins, '*' for all, or unset to deny all
# CORS_ORIGIN=https://your-app.example.com

# Set to 'false' to disable the Swagger UI at /docs (recommended in production)
# SWAGGER_ENABLED=false
