{
    "name": "logseq-api-gateway",
    "version": "0.1.0",
    "description": "REST API Gateway for Logseq with RBAC, write serialization, and OpenAPI documentation",
    "source": "src/index.ts",
    "main": "dist/index.js",
    "targets": {
        "main": {
            "context": "node",
            "includeNodeModules": false,
            "outputFormat": "commonjs",
            "optimize": true,
            "isLibrary": false
        }
    },
    "scripts": {
        "predev": "npm run build:dev",
        "dev": "concurrently \"tsc --watch\" \"nodemon --delay 2 --watch dist dist/index.js\"",
        "build": "npm run typecheck && npm run lint:openapi && parcel build && npm run copy:migrations",
        "build:dev": "tsc && npm run copy:migrations",
        "typecheck": "tsc --noEmit",
        "db:generate": "drizzle-kit generate",
        "copy:migrations": "mkdir -p dist/db && cp -r src/db/migrations dist/db/",
        "start": "node dist/index.js",
        "test": "jest",
        "lint": "eslint src/",
        "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\"",
        "docs": "typedoc",
        "generate:openapi": "TS_NODE_PROJECT=tsconfig.scripts.json ts-node scripts/generate-openapi.ts",
        "lint:openapi": "npm run generate:openapi && TS_NODE_PROJECT=tsconfig.scripts.json ts-node scripts/lint-openapi.ts",
        "seed": "TS_NODE_PROJECT=tsconfig.scripts.json ts-node scripts/seed.ts"
    },
    "dependencies": {
        "@fastify/cors": "^10.0.2",
        "@fastify/jwt": "^10.0.0",
        "@fastify/rate-limit": "^10.2.2",
        "@fastify/swagger": "^9.5.0",
        "@fastify/swagger-ui": "^5.2.3",
        "async-mutex": "^0.5.0",
        "bcryptjs": "^2.4.3",
        "better-sqlite3": "^11.9.1",
        "dotenv": "^16.4.7",
        "drizzle-orm": "^0.45.2",
        "fastify": "^5.3.3",
        "fastify-plugin": "^5.0.1",
        "undici": "^7.4.0",
        "uuid": "^11.1.0",
        "winston": "^3.11.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/better-sqlite3": "^7.6.12",
        "@types/jest": "^29.5.0",
        "@types/node": "^22.0.0",
        "@types/uuid": "^10.0.0",
        "concurrently": "^9.0.0",
        "drizzle-kit": "^0.31.10",
        "eslint": "^9.0.0",
        "eslint-plugin-prettier": "^5.0.0",
        "jest": "^29.0.0",
        "nodemon": "^3.0.0",
        "parcel": "^2.16.4",
        "prettier": "^3.0.0",
        "rmoa": "^1.0.0",
        "ts-jest": "^29.0.0",
        "ts-node": "^10.9.2",
        "typedoc": "^0.27.0",
        "typescript": "^5.8.0",
        "typescript-eslint": "^8.0.0"
    }
}
